# Port the addon server runs on (Default: 7860)
PORT=7860

# Public URL of your deployed addon (e.g., https://stremio-tg.yourdomain.com)
ADDON_URL=http://localhost:7860

# Optional API Key to secure your addon (e.g., Gvi4ShwFyYz...)
API_KEY=

# Telegram API credentials from https://my.telegram.org
API_ID=
API_HASH=

# Telegram Bot Token from @BotFather (required if USER_SESSION_STRING is not set)
BOT_TOKEN=

# Telegram User Session String (highly recommended to bypass 2GB file limit)
USER_SESSION_STRING=

# Comma-separated list of Telegram Channel IDs to index (e.g., -100xxxxxxxxxx, -100yyyyyyyyyy)
TELEGRAM_CHANNEL_ID=

# Optional: subset of channels to search/stream by default (must be listed in TELEGRAM_CHANNEL_ID)
# Leave empty to use all configured channels. Override per install with ?channels= on the manifest URL.
ACTIVE_CHANNEL_IDS=

# Optional: Channel ID to send play/stream logs to (e.g., -100zzzzzzzzzz)
LOG_CHANNEL_ID=

# Optional: Timezone for logging (e.g., Asia/Kolkata, UTC). Defaults to UTC.
TIMEZONE=UTC

# Optional: Cache duration in seconds for search queries (Default: 1800)
CACHE_TTL=1800
